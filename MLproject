name: metabolite-gprediction

entry_points:
  train:
    parameters:
      data: {type: str, default: train.csv}
      epochs: {type: int, default: 20}
      batch_size: {type: int, default: 16}
      lr: {type: float, default: 0.0001}
      device: {type: str, default: auto}
      representation: {type: str, default: selfies}
      output_dir: {type: str, default: artifacts}
      run_name: {type: str, default: mlflow_project_run}
      mlflow_experiment: {type: str, default: metabolite-predictor}
      mlflow_tracking_uri: {type: str, default: file:./mlruns}
    command: >
      python train.py
      --data {data}
      --epochs {epochs}
      --batch_size {batch_size}
      --lr {lr}
      --device {device}
      --representation {representation}
      --output_dir {output_dir}
      --run_name {run_name}
      --use_mlflow
      --mlflow_experiment "{mlflow_experiment}"
      --mlflow_tracking_uri "{mlflow_tracking_uri}"

  evaluate_generation:
    parameters:
      data: {type: str, default: test.csv}
      model: {type: str, default: artifacts/mlflow_project_run/trained_model.best.pt}
      metadata: {type: str, default: artifacts/mlflow_project_run/trained_model.metadata.json}
      top_k: {type: int, default: 5}
      beam_width: {type: int, default: 5}
      device: {type: str, default: auto}
      mlflow_experiment: {type: str, default: metabolite-generation-eval}
      mlflow_run_name: {type: str, default: mlflow_project_run-eval}
      mlflow_tracking_uri: {type: str, default: file:./mlruns}
    command: >
      python evaluate_generation.py
      --data {data}
      --model {model}
      --metadata {metadata}
      --top_k {top_k}
      --beam_width {beam_width}
      --device {device}
      --use_mlflow
      --mlflow_experiment "{mlflow_experiment}"
      --mlflow_run_name "{mlflow_run_name}"
      --mlflow_tracking_uri "{mlflow_tracking_uri}"
